# Copy this file to .env.e2e and fill in the connectors you want to test.
# Env var names are auto-derived: <CONNECTOR_ID>_<FIELD_KEY>
#   e.g. qualys + baseUrl  → QUALYS_BASE_URL
#        tenable-io + accessKey → TENABLE_IO_ACCESS_KEY
# Connectors with any required field empty are automatically skipped.

# Qualys
QUALYS_BASE_URL=https://qualysapi.qualys.com
QUALYS_USERNAME=
QUALYS_PASSWORD=

# SentinelOne
SENTINELONE_BASE_URL=https://your-console.sentinelone.net
SENTINELONE_API_TOKEN=

# Jira
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=          # optional — auto-detected from getProjects if empty
JIRA_BOARD_ID=             # optional — only needed for getSprints / getActiveSprint

# Tenable.io
TENABLE_IO_ACCESS_KEY=
TENABLE_IO_SECRET_KEY=

# Tenable.sc
TENABLE_SC_BASE_URL=https://your-tenable-sc.company.com
TENABLE_SC_ACCESS_KEY=
TENABLE_SC_SECRET_KEY=

# Check Point  (CHECKPOINT_DOMAIN is optional)
CHECKPOINT_BASE_URL=https://your-checkpoint-mgmt:443
CHECKPOINT_USERNAME=
CHECKPOINT_PASSWORD=
CHECKPOINT_DOMAIN=

# ManageEngine
MANAGEENGINE_BASE_URL=https://your-manageengine.com
MANAGEENGINE_CLIENT_ID=
MANAGEENGINE_CLIENT_SECRET=
MANAGEENGINE_REFRESH_TOKEN=

# Zoho
ZOHO_BASE_URL=https://desk.zoho.com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
